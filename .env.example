# ── Matrix ────────────────────────────────────────────────
MATRIX_TOKEN=your_matrix_access_token
MATRIX_ROOM_ID=!your_room_id:matrix.org
MATRIX_HOMESERVER=https://matrix-client.matrix.org
MATRIX_USER=@your_username:matrix.org

# ── Ollama ────────────────────────────────────────────────
OLLAMA_MODEL=translategemma

# ── Channels ──────────────────────────────────────────────
# Channels are loaded from channels.txt (one handle per line).
# Override the file path here if needed:
# CHANNELS_FILE=channels.txt

# ── Polling (seconds) ────────────────────────────────────
# POLL_MIN=8
# POLL_MAX=15
